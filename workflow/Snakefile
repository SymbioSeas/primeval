import shutil
from pathlib import Path

# Config is supplied on the command line (primeval CLI passes --configfile;
# direct snakemake users pass --configfile config/config.yaml). No hardcoded
# configfile: directive, so the workflow parses from any working directory.

# Directory containing this Snakefile's scripts, resolved independently of cwd.
SCRIPTS = Path(workflow.basedir) / "scripts"

# Discover assemblies once at DAG-build time
ACCESSIONS = glob_wildcards(config["assembly_dir"] + "/{accession}.fna").accession
RESULTS = config["results_dir"]

# Raw BLAST TSVs are intermediate. By default they are wrapped in temp() so
# Snakemake deletes each once run_ispcr consumes it. Set keep_blast: true to
# retain them.
KEEP_BLAST = config.get("keep_blast", False)

# Per-assembly logs/ are intermediate; deleted on successful completion unless
# keep_logs: true. The top-level run.log (written by the primeval CLI) is kept.
KEEP_LOGS = config.get("keep_logs", False)


def blast_output(path):
    return path if KEEP_BLAST else temp(path)


rule all:
    input:
        RESULTS + "/reports/species_summary.csv",
        RESULTS + "/reports/assay_summary_long.csv",
        RESULTS + "/reports/assay_summary.xlsx",
        RESULTS + "/reports/detection_by_assembly.csv",
        RESULTS + "/reports/run_manifest.txt",
        RESULTS + "/reports/figures/species_detection_heatmap.pdf",


include: "rules/prepare.smk"
include: "rules/blast.smk"
include: "rules/ispcr.smk"
include: "rules/report.smk"


onsuccess:
    if not KEEP_LOGS:
        shutil.rmtree(Path(RESULTS) / "logs", ignore_errors=True)
